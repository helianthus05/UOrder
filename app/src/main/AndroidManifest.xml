<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UOrder">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".core.auth.SelectionActivity"
            android:exported="false" />
        <activity
            android:name=".core.auth.CustomerLoginActivity"
            android:exported="false" />
        <activity
            android:name=".core.auth.BusinessLoginActivity"
            android:exported="false" />
        <activity
            android:name=".core.auth.CustomerRegisterActivity"
            android:exported="false" />
        <activity
            android:name=".core.auth.BusinessRegisterActivity"
            android:exported="false" />
        <activity
            android:name=".core.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".core.admin.activities.AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".core.admin.activities.AdminMenuManageActivity"
            android:exported="false" />
        <activity
            android:name=".core.admin.activities.AdminAnalyticsActivity"
            android:exported="false" />
        <activity
            android:name=".core.admin.activities.ItemManageFoodActivity"
            android:exported="false" />
        <activity
            android:name=".core.student.activities.UserDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".core.student.activities.MenuActivity"
            android:exported="false" />
        <activity
            android:name=".core.student.activities.CheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".core.activities.HistoryActivity"
            android:exported="false" />
        <activity
            android:name=".core.student.activities.StallDetailActivity"
            android:exported="false" />
        <activity
            android:name=".core.activities.AccountSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".core.activities.ChangePasswordActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.uorder.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>